export const handler = async (event) => {

    const params = event.queryStringParameters || event || {};

    const a = Number(params.a);
    const b = Number(params.b);

    if (isNaN(a) || isNaN(b)) {
        return {
            statusCode: 400,
            body: JSON.stringify({
                error: "Please provide numbers a and b"
            })
        };
    }

    return {
        statusCode: 200,
        body: JSON.stringify({
            a: a,
            b: b,
            result: a + b
        })
    };

};
