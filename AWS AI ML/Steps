from pyspark.sql import SparkSession

spark = SparkSession.builder.appName("house-price-clean").getOrCreate()

# read dataset
df = spark.read.csv(
    "s3://house-price-ml-bucket-123/house_price_dataset.csv",
    header=True,
    inferSchema=True
)

# cleaning
df = df.dropna()
df = df.dropDuplicates()

# save cleaned data
df.write.mode("overwrite").csv(
    "s3://house-price-ml-bucket-123/cleaned-data/",
    header=True
)

print("SUCCESS")


